@page "/payment-success"

<PageTitle>Thanh toán thành công - Nhà hàng</PageTitle>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-lg border-0 text-center p-5">
                <i class="bi bi-check-circle-fill text-success display-1 mb-4"></i>
                <h2 class="fw-bold text-success">Thanh toán thành công!</h2>
                <p class="lead">Cảm ơn bạn đã đặt hàng. Đơn hàng của bạn đang được chuẩn bị.</p>

                @if (!string.IsNullOrEmpty(OrderId))
                {
                    <p><strong>Mã đơn hàng:</strong> @OrderId</p>
                }

                <div class="mt-4">
                    <a href="/customer-menu" class="btn btn-success btn-lg px-5">
                        <i class="bi bi-arrow-left"></i> Về trang thực đơn
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public string? OrderId { get; set; }
}