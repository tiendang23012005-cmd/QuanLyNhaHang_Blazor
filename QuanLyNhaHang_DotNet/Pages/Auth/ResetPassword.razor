@page "/reset-password"
@layout AuthLayout
@using QuanLyNhaHang_DotNet.Models
@inject QuanLyNhaHang_DotNet.Services.AuthService AuthService
@inject NavigationManager Router

<div class="container-fluid bg-light min-vh-100 d-flex align-items-center justify-content-center">
    <div class="row w-100 justify-content-center">
        <div class="col-11 col-sm-8 col-md-6 col-lg-4">
            <div class="card shadow-lg border-0 rounded-3 animate-fade-in">
                <div class="card-body p-4 p-sm-5">

                    <div class="text-center mb-4">
                        <h3 class="fw-bold text-warning text-uppercase m-0">Đặt lại mật khẩu</h3>
                        <small class="text-muted d-block mt-1">Nhập mật khẩu mới của bạn</small>
                    </div>

                    @if (isTokenInvalid)
                    {
                        <div class="alert alert-danger text-center">
                            Link không hợp lệ hoặc đã hết hạn.
                            <br />
                            <a href="/forgot-password" class="text-warning fw-semibold">Yêu cầu link mới</a>
                        </div>
                    }
                    else
                    {
                        <EditForm Model="@payload" OnValidSubmit="HandleSubmit">
                            <DataAnnotationsValidator />

                            <div class="mb-3">
                                <label class="form-label fw-semibold text-secondary small">Mật khẩu mới</label>
                                <InputText type="password" @bind-Value="payload.MatKhauMoi"
                                           class="form-control border-2" placeholder="******" />
                                <div class="text-danger small mt-1">
                                    <ValidationMessage For="@(() => payload.MatKhauMoi)" />
                                </div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-semibold text-secondary small">Nhập lại mật khẩu</label>
                                <InputText type="password" @bind-Value="payload.NhapLaiMatKhau"
                                           class="form-control border-2" placeholder="******" />
                                <div class="text-danger small mt-1">
                                    <ValidationMessage For="@(() => payload.NhapLaiMatKhau)" />
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(message))
                            {
                                <div class="alert @(isSuccess ? "alert-success" : "alert-danger") text-center p-2 small mb-3">
                                    @message
                                </div>
                            }

                            <button disabled="@isLoading" type="submit"
                                    class="btn btn-warning w-100 text-white fw-bold shadow-sm py-2">
                                @if (isLoading)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                    <span>ĐANG XỬ LÝ...</span>
                                }
                                else
                                {
                                    <span>ĐẶT LẠI MẬT KHẨU</span>
                                }
                            </button>
                        </EditForm>
                    }

                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private ResetPasswordRequest payload = new();
    private string message = string.Empty;
    private bool isSuccess = false;
    private bool isLoading = false;
    private bool isTokenInvalid = false;

    protected override void OnInitialized()
    {
        // Lấy email và token từ URL
        var uri = new Uri(Router.Uri);
        var query = uri.Query.TrimStart('?')
            .Split('&')
            .Select(p => p.Split('=', 2))
            .Where(p => p.Length == 2)
            .ToDictionary(p => Uri.UnescapeDataString(p[0]),
                          p => Uri.UnescapeDataString(p[1]));

        if (!query.TryGetValue("email", out var email) ||
            !query.TryGetValue("token", out var token))
        {
            isTokenInvalid = true;
            return;
        }

        payload.Email = email;
        payload.Token = token;
    }

    private async Task HandleSubmit()
    {
        isLoading = true;
        message = string.Empty;
        try
        {
            var res = await AuthService.ResetPasswordAsync(payload);
            isSuccess = res?.IsSuccess ?? false;
            message = res?.Message ?? "Đã xảy ra lỗi.";

            if (isSuccess)
            {
                await Task.Delay(1500);
                Router.NavigateTo("/login");
            }
        }
        catch
        {
            isSuccess = false;
            message = "Lỗi kết nối server. Vui lòng thử lại.";
        }
        finally { isLoading = false; }
    }
}