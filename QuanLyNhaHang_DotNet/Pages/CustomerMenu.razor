@page "/menu"
@page "/"
@using System.Net.Http.Json
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Navigation
@inject HttpClient Http
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS

<div class="container py-5">
    <div class="row">
        <div class="col-md-8">
            <div class="d-flex align-items-center mb-4 pb-2 border-bottom border-warning">
                <i class="bi bi-shop fs-2 text-warning me-3"></i>
                <h2 class="fw-bold text-dark m-0">THỰC ĐƠN <span class="text-warning">HÔM NAY</span></h2>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger rounded-3 shadow-sm">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@errorMessage
                </div>
            }

            <div class="row g-4">
                @foreach (var item in menuItems)
                {
                    <div class="col-12 col-sm-6 col-lg-4">
                        <div class="card h-100 shadow-sm border border-light food-card position-relative">

                            <div class="food-img-wrapper">
                                <img src="@(!string.IsNullOrEmpty(item.HinhAnh) ? item.HinhAnh : "https://images.unsplash.com/photo-1546069901-ba9599a7e63c?q=80&w=500&auto=format&fit=crop")"
                                     class="card-img-top" alt="food" style="object-fit: cover; height: 220px;">
                            </div>

                            <div class="card-body d-flex flex-column text-center p-4">
                                <h5 class="card-title fw-bold text-dark mb-1">@item.TenMonAn</h5>
                                <p class="text-muted small mb-3">@(string.IsNullOrEmpty(item.MoTa) ? "Món ăn ngon đậm đà hương vị truyền thống." : item.MoTa)</p>

                                <div class="mt-auto">
                                    <h4 class="text-danger fw-bold mb-3">@item.Gia.ToString("#,##0")<span class="fs-6 text-muted ms-1">VNĐ</span></h4>
                                    <button class="btn btn-warning w-100 fw-bold text-dark rounded-pill py-2 shadow-sm" @onclick="() => OnAddToCart(item)">
                                        <i class="bi bi-cart-plus-fill me-1"></i> Thêm vào giỏ
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="col-md-4 mt-5 mt-md-0">
            <div class="card shadow border-0 sticky-top rounded-4" style="top: 20px;">
                <div class="card-header bg-warning text-dark fw-bold py-3 rounded-top-4 border-0 d-flex align-items-center justify-content-between">
                    <span class="fs-5"><i class="bi bi-bag-check-fill me-2"></i>GIỎ HÀNG</span>
                    <span class="badge bg-danger rounded-pill fs-6">@cartItems.Count</span>
                </div>

                <div class="card-body p-0 cart-scroll">
                    <ul class="list-group list-group-flush">
                        @if (cartItems.Count == 0)
                        {
                            <li class="list-group-item text-center text-muted py-5 border-0">
                                <i class="bi bi-cart-x fs-1 d-block mb-2 text-light"></i>
                                Chưa có món nào trong giỏ
                            </li>
                        }

                        @foreach (var cart in cartItems)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center py-3 border-bottom-dashed">
                                <div class="me-2">
                                    <span class="fw-bold d-block text-dark">@cart.MonAn.TenMonAn</span>
                                    <small class="text-muted">@cart.MonAn.Gia.ToString("#,##0")đ <i class="bi bi-x"></i> <span class="fw-bold">@cart.SoLuong</span></small>
                                </div>
                                <div class="d-flex align-items-center text-end">
                                    <span class="fw-bold text-danger me-2">@((cart.MonAn.Gia * cart.SoLuong).ToString("#,##0"))đ</span>
                                    <button class="btn btn-sm btn-danger rounded-circle p-0 d-flex align-items-center justify-content-center shadow-sm"
                                            style="width: 28px; height: 28px;"
                                            @onclick="() => OnRemoveFromCart(cart.MonAn.MaMonAn)">
                                        <span class="fw-bold text-white" style="font-size: 14px;">X</span>
                                    </button>
                                </div>
                            </li>
                        }
                    </ul>
                </div>

                <div class="card-footer bg-white border-top-0 rounded-bottom-4 p-4">
                    <div class="mb-4 bg-light p-3 rounded-3 border">
                        <h6 class="fw-bold mb-3"><i class="bi bi-card-checklist me-2"></i>Thông tin đơn hàng</h6>

                        <div class="mb-3">
                            <label class="form-label text-muted small fw-bold">Loại đơn:</label>
                            <div class="d-flex gap-3">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="orderType" id="mangVe"
                                           checked="@(selectedOrderType == "Mang về")"
                                           @onchange="@(() => selectedOrderType = "Mang về")">
                                    <label class="form-check-label" for="mangVe">Mang về</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="orderType" id="taiQuan"
                                           checked="@(selectedOrderType == "Tại quán")"
                                           @onchange="@(() => selectedOrderType = "Tại quán")">
                                    <label class="form-check-label" for="taiQuan">Tại quán</label>
                                </div>
                            </div>
                        </div>

                        @if (selectedOrderType == "Tại quán")
                        {
                            <div class="mb-3">
                                <label class="form-label text-muted small fw-bold">Chọn bàn ăn (*):</label>
                                <select class="form-select form-select-sm" @bind="selectedTable">
                                    <option value="" disabled selected>-- Vui lòng chọn bàn --</option>
                                    @foreach (var ban in danhSachBan.Where(b => b.TrangThaiBan == "Trống"))
                                    {
                                        <option value="@ban.MaBan">@ban.SoBan (sức chứa: @ban.SucChua người)</option>
                                    }
                                    @foreach (var ban in danhSachBan.Where(b => b.TrangThaiBan != "Trống"))
                                    {
                                        <option value="@ban.MaBan" disabled style="color:gray">
                                            @ban.SoBan — Đang có khách
                                        </option>
                                    }
                                </select>
                            </div>
                        }

                        <div class="mb-3">
                            <label class="form-label text-muted small fw-bold">Thanh toán:</label>
                            <select class="form-select form-select-sm" @bind="selectedPayment">
                                <option value="Tiền mặt">Tiền mặt</option>
                                <option value="Chuyển khoản">Chuyển khoản</option>
                                <option value="VNPay">Ví VNPay</option>
                            </select>
                        </div>

                        <div class="mb-2">
                            <label class="form-label text-muted small fw-bold">Ghi chú (Tùy chọn):</label>
                            <textarea class="form-control form-control-sm" rows="2" placeholder="Ví dụ: Không hành, nhiều đá..." @bind="orderNote"></textarea>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-4 border-top pt-3">
                        <span class="text-muted fw-bold text-uppercase">Tổng thanh toán:</span>
                        <span class="text-danger fw-bolder fs-4">@TotalPrice.ToString("#,##0")đ</span>
                    </div>

                    @if (!string.IsNullOrEmpty(successMessage))
                    {
                        <div class="alert alert-success small p-2 text-center rounded-3 shadow-sm">
                            <i class="bi bi-check-circle-fill me-1"></i>@successMessage
                        </div>
                    }

                    <button class="btn btn-danger w-100 fw-bold fs-5 py-3 rounded-pill shadow"
                            disabled="@(cartItems.Count == 0 || isOrdering)"
                            @onclick="OnCheckout">
                        @if (isOrdering)
                        {
                            <span>ĐANG XỬ LÝ...</span>
                        }
                        else
                        {
                            <span>ĐẶT MÓN NGAY <i class="bi bi-arrow-right-circle ms-1"></i></span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<MonAnModel> menuItems = new();
    private List<CartItemModel> cartItems = new();
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;
    private bool isOrdering = false;

    private string selectedOrderType = "Mang về";
    private string selectedPayment = "Tiền mặt";
    private int? selectedTable = null;
    private string orderNote = string.Empty;

    private decimal TotalPrice => cartItems.Sum(x => x.MonAn.Gia * x.SoLuong);

    // ✅ ĐỔI THÀNH: khai báo rỗng
    private List<BanAnModel> danhSachBan = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadMenuAsync();
        await LoadDanhSachBanAsync(); // ✅ THÊM DÒNG NÀY
    }

    private async Task LoadDanhSachBanAsync()
    {
        try
        {
            // ✅ Đúng route theo TableManagementController
            var data = await Http.GetFromJsonAsync<List<BanAnModel>>("api/TableManagement");
            if (data != null) danhSachBan = data;
        }
        catch (Exception ex)
        {
            Console.WriteLine("Lỗi tải danh sách bàn: " + ex.Message);
        }
    }

    private async Task LoadMenuAsync()
    {
        try
        {
            var data = await Http.GetFromJsonAsync<List<MonAnModel>>("api/MonAn");
            if (data != null) menuItems = data;
        }
        catch (Exception)
        {
            errorMessage = "Không thể tải thực đơn!";
        }
    }

    // Kiểm tra Đăng nhập trước khi cho phép thêm món ăn vào giỏ hàng
    private async Task OnAddToCart(MonAnModel monAn)
    {
        errorMessage = string.Empty;
        successMessage = string.Empty;

        // 1. Kiểm tra trạng thái xác thực từ hệ thống
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity == null || !user.Identity.IsAuthenticated)
        {
            // Nếu chưa đăng nhập, hiện thông báo và chuyển hướng sang trang đăng nhập ngay
            await JS.InvokeVoidAsync("alert", "Vui lòng đăng nhập tài khoản để thực hiện chức năng đặt món!");
            Navigation.NavigateTo("/login", forceLoad: false);
            return;
        }

        // 2. Nếu đã đăng nhập, thực hiện logic thêm vào giỏ như bình thường
        var existing = cartItems.FirstOrDefault(x => x.MonAn.MaMonAn == monAn.MaMonAn);
        if (existing != null) existing.SoLuong++;
        else cartItems.Add(new CartItemModel { MonAn = monAn, SoLuong = 1 });
    }

    private void OnRemoveFromCart(int maMonAn)
    {
        var item = cartItems.FirstOrDefault(x => x.MonAn.MaMonAn == maMonAn);
        if (item != null) cartItems.Remove(item);
    }

    // Kiểm tra Đăng nhập trước khi xử lý nhấn nút ĐẶT MÓN NGAY
    private async Task OnCheckout()
    {
        if (cartItems.Count == 0) return;

        errorMessage = string.Empty;
        successMessage = string.Empty;

        // 1. Kiểm tra trạng thái đăng nhập phòng trường hợp hy hữu người dùng xóa dữ liệu thủ công
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity == null || !user.Identity.IsAuthenticated)
        {
            await JS.InvokeVoidAsync("alert", "Phiên đăng nhập đã hết hạn. Vui lòng đăng nhập lại để hoàn tất đặt món!");
            Navigation.NavigateTo("/login", forceLoad: false);
            return;
        }

        Console.WriteLine($"[DEBUG] selectedPayment = '{selectedPayment}'");

        if (selectedOrderType == "Tại quán" && selectedTable == null)
        {
            errorMessage = "Vui lòng chọn số bàn!";
            return;
        }

        isOrdering = true;

        var orderPayload = new OrderRequestDTO
            {
                LoaiDonHang = selectedOrderType,
                PhuongThucThanhToan = selectedPayment,
                MaBan = selectedOrderType == "Tại quán" ? selectedTable : null,
                GhiChu = orderNote,
                ChiTietDonHang = cartItems.Select(item => new ChiTietDonHangDTO
                {
                    MaMonAn = item.MonAn.MaMonAn,
                    SoLuong = item.SoLuong,
                    GiaLucDat = item.MonAn.Gia
                }).ToList()
            };

        try
        {
            if (selectedPayment?.Trim().Equals("VNPay", StringComparison.OrdinalIgnoreCase) == true)
            {
                Console.WriteLine("→ Gọi API VNPay...");
                await ProcessVNPayPayment(orderPayload);
            }
            else
            {
                var response = await Http.PostAsJsonAsync("api/DonHang/create", orderPayload);
                if (response.IsSuccessStatusCode)
                {
                    successMessage = "Đặt món thành công!";
                    cartItems.Clear();
                    orderNote = string.Empty;
                }
                else
                {
                    errorMessage = "Đặt hàng thất bại!";
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Lỗi kết nối: " + ex.Message;
        }
        finally
        {
            isOrdering = false;
        }
    }

    private async Task ProcessVNPayPayment(OrderRequestDTO orderPayload)
    {
        try
        {
            var response = await Http.PostAsJsonAsync("api/payment/create", orderPayload);
            var responseText = await response.Content.ReadAsStringAsync();
            Console.WriteLine($"[VNPay API Response] {response.StatusCode} - {responseText}");

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<JsonElement>();
                if (result.TryGetProperty("isSuccess", out var success) && success.GetBoolean())
                {
                    string paymentUrl = result.GetProperty("paymentUrl").GetString()!;
                    Navigation.NavigateTo(paymentUrl, true);
                    return;
                }
            }

            errorMessage = "Không tạo được link thanh toán VNPay.";
        }
        catch (Exception ex)
        {
            errorMessage = "Lỗi VNPay: " + ex.Message;
            Console.WriteLine(ex.ToString());
        }
    }

    // Tầng DTOs / Models nội bộ
    public class MonAnModel
    {
        public int MaMonAn { get; set; }
        public string TenMonAn { get; set; } = string.Empty;
        public string? MoTa { get; set; }
        public string? HinhAnh { get; set; }
        public decimal Gia { get; set; }
    }

    public class CartItemModel
    {
        public MonAnModel MonAn { get; set; } = new();
        public int SoLuong { get; set; }
    }

    public class BanAnModel
    {
        public int MaBan { get; set; }
        public string SoBan { get; set; } = string.Empty;
        public int SucChua { get; set; }
        public string? TrangThaiBan { get; set; }  // ✅ đúng tên field
    }
}