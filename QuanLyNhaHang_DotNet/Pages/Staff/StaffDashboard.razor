@page "/staff-dashboard"
@using QuanLyNhaHang_DotNet.Models
@using QuanLyNhaHang_DotNet.Services
@using System.Text.Json
@inject NhanVienService NhanVienService
@inject HttpClient Http
@inject NavigationManager Navigation
@inject Microsoft.JSInterop.IJSRuntime JS
@implements IDisposable

@if (!isAuthorized)
{
    <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:100vh;background:#f8f9fa">
        <div class="spinner-border text-warning mb-3" role="status"></div>
        <h5 class="text-secondary fw-semibold">Đang kiểm tra quyền truy cập...</h5>
    </div>
}
else
{
    <div class="dashboard-container">

        @* SƠ ĐỒ BÀN *@
        <div class="tables-section">
            <div class="section-title"><h2>Sơ đồ phục vụ POS</h2></div>

            <div class="takeaway-box">
                <div class="table-card status-takeaway @(banDangChon?.MaBan == 0 ? "active-selection" : "")"
                     @onclick="ChonMangVe">
                    <div class="icon-ban"><i class="fas fa-shopping-bag"></i></div>
                    <span class="table-number">MANG VỀ</span>
                    <span class="table-status">Bấm xử lý nhanh</span>
                </div>
            </div>

            @if (isLoading)
            {
                <div class="loading-spinner">Đang tải sơ đồ...</div>
            }
            else
            {
                <div class="grid-tables">
                    @foreach (var ban in danhSachBan)
                    {
                        <div class="table-card @(ban.TrangThaiBan == "Trống" ? "status-trong" : "status-phuc-vu") @(banDangChon?.MaBan == ban.MaBan ? "active-selection" : "")"
                             @onclick="async () => await ChonBan(ban)">
                            <div class="icon-ban"><i class="fas fa-users"></i></div>
                            <span class="table-number">@ban.SoBan</span>
                            <span class="table-status">@ban.TrangThaiBan</span>
                        </div>
                    }
                </div>
            }
        </div>

        @* PANEL ĐƠN HÀNG *@
        <div class="orders-section">
            @if (banDangChon == null)
            {
                <div class="empty-state">
                    <i class="fas fa-arrow-left"></i>
                    <p>Vui lòng chọn một bàn hoặc ô "Mang Về"</p>
                </div>
            }
            else if (donHangHienTai == null)
            {
                <div class="empty-state">
                    <h3>@banDangChon.SoBan</h3>
                    <p class="txt-warning">Hiện tại chưa có hóa đơn nào.</p>
                    <button class="btn-primary-action" @onclick="MoModalThemMon">
                        <i class="fas fa-plus"></i> Tạo hóa đơn & Gọi món ngay
                    </button>
                </div>
            }
            else
            {
                <div class="bill-wrapper">
                    <div class="bill-header">
                        <h3>@banDangChon.SoBan <small class="badge-process">Đang phục vụ</small></h3>
                        <span class="ma-don">Mã HĐ: #@donHangHienTai.MaDonHang</span>
                    </div>

                    <button class="btn-them-mon" @onclick="MoModalThemMon">
                        <i class="fas fa-cart-plus"></i> Thêm món ăn vào đơn
                    </button>

                    <div class="bill-items-list">
                        @foreach (var item in donHangHienTai.ChiTietDonHangs ?? new())
                        {
                            <div class="bill-item">
                                <div class="item-info">
                                    <span class="item-name">@item.TenMonAn</span>
                                    <span class="item-price">@item.GiaLucDat.ToString("N0")đ</span>
                                </div>
                                <div class="item-qty-control">
                                    <button class="qty-btn" @onclick="() => ThayDoiSoLuong(item.MaChiTiet, item.SoLuong, -1)">-</button>
                                    <input type="text" class="qty-input" value="@item.SoLuong" readonly />
                                    <button class="qty-btn" @onclick="() => ThayDoiSoLuong(item.MaChiTiet, item.SoLuong, 1)">+</button>
                                </div>
                                <div class="item-total">@item.ThanhTien.ToString("N0")đ</div>
                            </div>
                        }
                    </div>

                    <div class="bill-summary">
                        <div class="summary-row">
                            <span>Tạm tính</span>
                            <strong>@donHangHienTai.TongTien.ToString("N0")đ</strong>
                        </div>
                        <div class="summary-row">
                            <span>Khấu trừ giảm giá</span>
                            <strong>0đ</strong>
                        </div>
                        <div class="summary-row total-row">
                            <span>TỔNG CỘNG THANH TOÁN</span>
                            <span class="total-price">@donHangHienTai.TongTien.ToString("N0")đ</span>
                        </div>
                    </div>

                    <div class="bill-actions">
                        <button class="btn-huy" @onclick="HuyDonHang">
                            <i class="fas fa-trash-alt"></i> Xóa đơn
                        </button>
                        <button class="btn-in" @onclick="InTamTinh">In tạm tính</button>
                        <button class="btn-thanhtoan" @onclick="YeuCauThanhToan">Thanh toán (F9)</button>
                    </div>
                </div>
            }
        </div>
    </div>
}

@* MODAL THÊM MÓN *@
@if (hienThiModalThemMon)
{
    <div class="modal-overlay">
        <div class="modal-content">
            <div class="modal-header">
                <h3>Danh sách thực đơn nhà hàng</h3>
                <button class="btn-close" @onclick="DongModalThemMon">&times;</button>
            </div>
            <div class="modal-body">
                <table class="menu-table">
                    <thead>
                        <tr>
                            <th>Mã món</th>
                            <th>Tên món ăn</th>
                            <th>Đơn giá</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (danhSachMonAn.Any())
                        {
                            @foreach (var mon in danhSachMonAn)
                            {
                                <tr>
                                    <td>@mon.MaMonAn</td>
                                    <td><strong>@mon.TenMonAn</strong></td>
                                    <td class="txt-price">@mon.Gia.ToString("N0")đ</td>
                                    <td>
                                        <button class="btn-add-item" @onclick="() => ThemMonVaoDon(mon)">
                                            <i class="fas fa-plus-circle"></i> Thêm
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="4" class="text-center text-muted py-3">⏳ Đang tải thực đơn...</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@* MODAL XÁC NHẬN THANH TOÁN *@
@if (hienThiModalXacNhanThanhToan)
{
    <div class="modal-overlay no-print">
        <div class="modal-confirm-content">
            <div class="modal-confirm-header danger">
                <i class="fas fa-exclamation-circle"></i> XÁC NHẬN THANH TOÁN
            </div>
            <div class="modal-confirm-body">
                Bạn có chắc muốn thanh toán đơn hàng cho <strong>@banDangChon?.SoBan</strong>?<br />
                Bàn sẽ được chuyển về trạng thái <strong>Trống</strong>.
            </div>
            <div class="modal-confirm-footer">
                <button class="btn-cancel" @onclick="() => hienThiModalXacNhanThanhToan = false">Hủy bỏ</button>
                <button class="btn-confirm" @onclick="ThucHienThanhToanAPI">Đồng ý thanh toán</button>
            </div>
        </div>
    </div>
}

@* MODAL HỎI IN SAU THANH TOÁN *@
@if (hienThiModalHoiIn)
{
    <div class="modal-overlay no-print">
        <div class="modal-confirm-content">
            <div class="modal-confirm-header success">
                <i class="fas fa-check-circle"></i> THANH TOÁN THÀNH CÔNG!
            </div>
            <div class="modal-confirm-body text-center">
                Đơn hàng đã được lưu thành công.<br />
                Bạn có muốn <strong>In hóa đơn thanh toán</strong> ngay không?
            </div>
            <div class="modal-confirm-footer justify-center">
                <button class="btn-no-print" @onclick="BoQuaIn">
                    <i class="fas fa-times"></i> Không cần in
                </button>
                <button class="btn-yes-print" @onclick="DongYIn">
                    <i class="fas fa-print"></i> Có, In hóa đơn
                </button>
            </div>
        </div>
    </div>
}

@* MODAL XEM & IN HÓA ĐƠN *@
@if (hienThiModalIn)
{
    <div class="modal-overlay invoice-print-modal" @onclick="DongModalIn">
        <div class="modal-content-invoice" @onclick:stopPropagation>
            <div class="invoice-pos-paper">
                <div class="invoice-header">
                    <h3 class="restaurant-name">NHÀ HÀNG ĐẶC SẢN QUY NHƠN</h3>
                    <p class="restaurant-info">ĐC: 123 Nguyễn Huệ, TP. Quy Nhơn</p>
                    <p class="restaurant-info">ĐT: 0905.XXX.XXX</p>
                    <div class="dashed-line"></div>
                    <h2 class="invoice-title">@(loaiIn == "tam-tinh" ? "PHIẾU TẠM TÍNH" : "HÓA ĐƠN THANH TOÁN")</h2>
                    <p class="invoice-meta">Mã HĐ: #@donHangHienTai?.MaDonHang</p>
                    <p class="invoice-meta">Thời gian: @ngayIn.ToString("dd/MM/yyyy HH:mm")</p>
                </div>

                <div class="invoice-info">
                    <p><strong>Vị trí:</strong> @(donHangHienTai?.SoBan != null ? $"Bàn {donHangHienTai.SoBan}" : "Mang về")</p>
                    <p><strong>Thu ngân:</strong> Nhân viên phục vụ</p>
                </div>

                <div class="dashed-line"></div>

                <table class="invoice-table" style="width:100%;table-layout:fixed">
                    <colgroup>
                        <col style="width:42%" />
                        <col style="width:10%" />
                        <col style="width:24%" />
                        <col style="width:24%" />
                    </colgroup>
                    <thead>
                        <tr>
                            <th align="left">Món ăn</th>
                            <th align="center">SL</th>
                            <th align="right">Đơn giá</th>
                            <th align="right">T.Tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in donHangHienTai?.ChiTietDonHangs ?? new())
                        {
                            <tr>
                                <td align="left" style="word-break:break-word;white-space:normal">@item.TenMonAn</td>
                                <td align="center">@item.SoLuong</td>
                                <td align="right">@item.GiaLucDat.ToString("N0")</td>
                                <td align="right" class="font-bold">@item.ThanhTien.ToString("N0")</td>
                            </tr>
                        }
                    </tbody>
                </table>

                <div class="dashed-line"></div>

                <div class="invoice-summary">
                    <div class="summary-line">
                        <span>Tổng tiền món:</span>
                        <span>@donHangHienTai?.TongTien.ToString("N0")đ</span>
                    </div>
                    <div class="summary-line">
                        <span>Giảm giá / Ưu đãi:</span>
                        <span>0đ</span>
                    </div>
                    <div class="dashed-line"></div>
                    <div class="summary-line total-pay">
                        <span>THÀNH TIỀN:</span>
                        <span>@donHangHienTai?.TongTien.ToString("N0")đ</span>
                    </div>
                </div>

                <div class="dashed-line"></div>
                <div class="invoice-footer">
                    <p class="thank-you">CẢM ƠN QUÝ KHÁCH & HẸN GẶP LẠI!</p>
                    <p class="powered-by">Phần mềm quản lý nhà hàng v1.0</p>
                </div>
            </div>

            <div class="modal-footer-tools no-print">
                <button class="btn-close-view" @onclick="DongModalIn">
                    <i class="fas fa-arrow-left"></i> Quay lại
                </button>
                @* Trong HTML — đổi thành gọi hàm *@
                <button class="btn-trigger-print" @onclick="KichHoatIn">
                    <i class="fas fa-print"></i> In ra giấy
                </button>
            </div>
        </div>
    </div>
}

@code {
    // State
    private List<BanAnDto> danhSachBan = new();
    private List<MonAn> danhSachMonAn = new();
    private BanAnDto? banDangChon;
    private DonHangHienTaiDto? donHangHienTai;

    // UI flags
    private bool isLoading = true;
    private bool isAuthorized = true;
    private bool hienThiModalThemMon;
    private bool hienThiModalXacNhanThanhToan;
    private bool hienThiModalHoiIn;
    private bool hienThiModalIn;

    // In hóa đơn
    private string loaiIn = "tam-tinh";
    private DateTime ngayIn = DateTime.Now;

    // Polling
    private System.Threading.Timer? pollingTimer;

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadDanhSachBan(), LoadDanhSachMonAn());

        pollingTimer = new System.Threading.Timer(async _ =>
            await InvokeAsync(async () =>
            {
                await LoadDanhSachBan();
                if (banDangChon != null)
                    await RefreshDonHang(banDangChon.MaBan);
                StateHasChanged();
            }),
        null, 15_000, 15_000);
    }

    private async Task LoadDanhSachBan()
    {
        var res = await NhanVienService.GetDanhSachBanAsync();
        if (res?.IsSuccess == true) danhSachBan = res.Data ?? new();
        isLoading = false;
    }

    private async Task LoadDanhSachMonAn()
    {
        try
        {
            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var json = await Http.GetStringAsync("https://localhost:7043/api/MonAn");

            using var doc = JsonDocument.Parse(json);
            var root = doc.RootElement;

            danhSachMonAn = root.ValueKind == JsonValueKind.Array
                ? JsonSerializer.Deserialize<List<MonAn>>(json, options) ?? new()
                : root.TryGetProperty("data", out var prop) || root.TryGetProperty("Data", out prop)
                    ? JsonSerializer.Deserialize<List<MonAn>>(prop.GetRawText(), options) ?? new()
                    : new();
        }
        catch (Exception ex) { Console.WriteLine($"Lỗi tải thực đơn: {ex.Message}"); }
    }

    private async Task ChonBan(BanAnDto ban)
    {
        banDangChon = ban;
        await RefreshDonHang(ban.MaBan);
    }

    private async Task ChonMangVe()
    {
        banDangChon = new BanAnDto { MaBan = 0, SoBan = "Đơn Mang Về", TrangThaiBan = "Mang về" };
        await RefreshDonHang(0);
    }

    private async Task RefreshDonHang(int maBan)
        => donHangHienTai = await NhanVienService.GetDonHangTheoBanAsync(maBan);

    private async Task ThayDoiSoLuong(int maChiTiet, int soLuong, int delta)
    {
        int soLuongMoi = soLuong + delta;
        if (soLuongMoi < 0) return;
        var res = await NhanVienService.CapNhatSoLuongMonAsync(maChiTiet, soLuongMoi);
        if (res.IsSuccessStatusCode && banDangChon != null)
            await RefreshDonHang(banDangChon.MaBan);
    }

    private async Task ThemMonVaoDon(MonAn mon)
    {
        int maDonHang = donHangHienTai?.MaDonHang ?? 0;
        int maBan = banDangChon?.MaBan ?? 0;
        var res = await NhanVienService.ThemMonVaoDonHienTaiAsync(maDonHang, mon.MaMonAn, 1, maBan);
        if (res.IsSuccessStatusCode && banDangChon != null)
        {
            DongModalThemMon();
            await RefreshDonHang(banDangChon.MaBan);
            await LoadDanhSachBan();
        }
    }

    private async Task ThucHienThanhToanAPI()
    {
        if (donHangHienTai == null) return;
        var res = await NhanVienService.XacNhanThanhToanAsync(donHangHienTai.MaDonHang);
        if (res.IsSuccessStatusCode)
        {
            hienThiModalXacNhanThanhToan = false;
            ngayIn = DateTime.Now;
            hienThiModalHoiIn = true;
        }
        else
            await JS.InvokeVoidAsync("alert", "Lỗi trong quá trình xử lý thanh toán.");
    }

    private async Task HuyDonHang()
    {
        if (donHangHienTai == null) return;
        bool ok = await JS.InvokeAsync<bool>("confirm", $"Xác nhận HỦY đơn hàng của {banDangChon?.SoBan}?");
        if (!ok) return;
        var res = await NhanVienService.HuyDonHangAsync(donHangHienTai.MaDonHang);
        if (res.IsSuccessStatusCode)
        {
            await JS.InvokeVoidAsync("alert", "Đã hủy đơn hàng thành công!");
            ResetSauThanhToan();
        }
    }

    // Các hàm điều khiển modal gọn
    private void InTamTinh() { if (donHangHienTai == null) return; ngayIn = DateTime.Now; loaiIn = "tam-tinh"; hienThiModalIn = true; }
    private void YeuCauThanhToan() => hienThiModalXacNhanThanhToan = true;
    private void DongYIn() { hienThiModalHoiIn = false; loaiIn = "hoa-don"; hienThiModalIn = true; }
    private void BoQuaIn() { hienThiModalHoiIn = false; ResetSauThanhToan(); }
    private void DongModalIn() { hienThiModalIn = false; if (loaiIn == "hoa-don") ResetSauThanhToan(); }
    private void MoModalThemMon() => hienThiModalThemMon = true;
    private void DongModalThemMon() => hienThiModalThemMon = false;
    // Trong @code — thêm hàm này
    private async Task KichHoatIn()
        => await JS.InvokeVoidAsync("window.print");

    private void ResetSauThanhToan()
    {
        donHangHienTai = null;
        banDangChon = null;
        _ = LoadDanhSachBan();
    }

    public void Dispose() => pollingTimer?.Dispose();
}
