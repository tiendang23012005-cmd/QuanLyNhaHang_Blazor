@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject QuanLyNhaHang_DotNet.Services.AuthService AuthInterface

<nav class="navbar navbar-dark bg-dark px-4 py-3 shadow-sm">
    <div class="container-fluid d-flex justify-content-between align-items-center">
        <a class="navbar-brand fw-bold fs-4" href="/">
            Nhà hàng đặc sản Quy Nhơn
        </a>

        <div class="d-flex align-items-center gap-3">
            <AuthorizeView>
                <Authorized>
                    @* Khối hiển thị khi đã ĐĂNG NHẬP THÀNH CÔNG *@
                    <span class="text-light me-3">
                        Xin chào, <strong>@(context.User.Identity?.Name ?? "Thành viên")</strong>

                        @* Dùng cú pháp này để kiểm tra xem Claim Role có null không trước khi chấm .Value *@
                        @if (context.User.FindFirst(System.Security.Claims.ClaimTypes.Role) != null)
                        {
                            <span class="badge bg-warning text-dark ms-2 font-bold-role">
                                @context.User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                            </span>
                        }
                    </span>
                    <button class="btn btn-outline-light btn-sm d-flex align-items-center gap-2" @onclick="ThucHienDangXuat">
                        <i class="bi bi-box-arrow-right"></i>
                        Đăng xuất
                    </button>
                </Authorized>
                <NotAuthorized>
                    @* Khối hiển thị khi chưa đăng nhập (Khách vãng lai) *@
                    <a href="/login" class="btn btn-outline-light btn-sm">
                        Đăng nhập
                    </a>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </div>
</nav>

<style>

    .navbar {
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%) !important;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
        border-bottom: 3px solid #ffc107;
        position: sticky;
        top: 0;
        z-index: 1030;
    }

    .navbar-brand {
        font-size: 1.5rem;
        font-weight: 700;
        color: #ffc107 !important;
        text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
        transition: all 0.3s ease;
    }

        .navbar-brand:hover {
            color: #ffdb4d !important;
            transform: scale(1.05);
        }

    .text-light {
        font-weight: 500;
        color: #e0e0e0 !important;
    }

    .font-bold-role {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        padding: 4px 8px;
    }

    .btn-outline-light {
        border-color: #ffc107;
        color: #ffc107;
        font-weight: 600;
        transition: all 0.3s ease;
        padding: 8px 16px;
        border-radius: 50px;
        background: transparent;
    }

        .btn-outline-light:hover {
            background-color: #ffc107;
            color: #1a1a2e;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(255, 193, 7, 0.4);
        }

    @@media (max-width: 768px) {
        .navbar {
            padding: 12px 16px !important;
        }

        .navbar-brand {
            font-size: 1.3rem;
        }
    }
</style>

@code {
    [Inject] private IJSRuntime JS { get; set; } = default!;

    protected override void OnInitialized()
    {
        // Lắng nghe trạng thái Auth thay đổi để vẽ lại UI
        AuthStateProvider.AuthenticationStateChanged += OnAuthenticationStateChanged;
    }

    private void OnAuthenticationStateChanged(Task<AuthenticationState> task)
    {
        // Ép Header render lại ngay lập tức khi trạng thái đăng nhập/đăng xuất thay đổi
        InvokeAsync(StateHasChanged);
    }

    private async Task ThucHienDangXuat()
    {
        try
        {
            // 1. Gọi hàm hủy session trong AuthService của bạn (nếu có xóa cookie/token nội bộ)
            await AuthInterface.LogoutAsync();
        }
        catch { }

        // 2. Xóa sạch Object đăng nhập trong sessionStorage
        await JS.InvokeVoidAsync("sessionStorage.removeItem", "currentUser");

        // 3. Thông báo cho hệ thống biết đã logout để đổi nút hiển thị thành "Đăng nhập"
        var customProvider = (CustomAuthStateProvider)AuthStateProvider;
        customProvider.NotifyUserLogout();

        // 4. Điều hướng về trang login
        Navigation.NavigateTo("/login", forceLoad: false);
    }

    public void Dispose()
    {
        // Hủy theo dõi để tránh rò rỉ bộ nhớ (Memory Leak)
        AuthStateProvider.AuthenticationStateChanged -= OnAuthenticationStateChanged;
    }
}